{
    "name": "your-org/address-engine",
    "description": "AddressEngine — domain-driven Address library with Symfony & ApiPlatform integration",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "ext-curl": "*",
        "ext-pdo": "*",
        "doctrine/orm": "^2.15 || ^3.0",
        "symfony/form": "^8.0",
        "symfony/framework-bundle": "^8.0",
        "symfony/intl": "^8.0",
        "symfony/property-access": "^8.0",
        "symfony/property-info": "^8.0",
        "symfony/serializer": "^8.0",
        "symfony/twig-bundle": "^8.0",
        "symfony/uid": "^8.0",
        "symfony/validator": "^8.0",
        "twig/twig": "^3.24"
    },
    "require-dev": {
        "behat/behat": "^3.14",
        "dbrekelmans/bdi": "^1.4",
        "deptrac/deptrac": "^3.0",
        "doctrine/data-fixtures": "2.2",
        "doctrine/doctrine-fixtures-bundle": "^4.3",
        "fakerphp/faker": "^1.23",
        "friends-of-behat/symfony-extension": "^2.1",
        "friendsofphp/php-cs-fixer": "^3.94",
        "phpstan/phpstan": "^1.11",
        "phpstan/phpstan-doctrine": "^1.5",
        "phpstan/phpstan-symfony": "^1.4",
        "phpunit/phpunit": "^10.5",
        "rector/rector": "^1.2",
        "symfony/dotenv": "^8.0",
        "symfony/panther": "^2.2",
        "vimeo/psalm": "^7.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "lint": "@php tools/qa/AddressPhpLint.php",
        "phpstan": "vendor/bin/phpstan analyse src --level=max",
        "psalm": "vendor/bin/psalm",
        "test": "@php tools/php/php84.php vendor/bin/phpunit -c phpunit.xml.dist",
        "stan": "@stan:conservative",
        "rector:dry": "vendor/bin/rector process --dry-run",
        "quality": [
            "@stan",
            "@rector:dry"
        ],
        "qa:phpstan": "php -d memory_limit=1G vendor/bin/phpstan analyse -c phpstan.neon.dist",
        "qa:rector": "php vendor/bin/rector process --dry-run",
        "qa:deptrac": "php vendor/bin/deptrac analyse --config-file=config/addressing_deptrac.yaml",
        "qa:cs": "php vendor/bin/php-cs-fixer fix --dry-run --diff --config=.php-cs-fixer.dist.php",
        "qa": [
            "@qa:phpstan",
            "@qa:deptrac",
            "@qa:rector"
        ],
        "inspection": "bash ./.commanding/sh/inspection.sh full",
        "inspection:bootstrap": "bash ./.commanding/sh/inspection.sh bootstrap",
        "inspection:run": "bash ./.commanding/sh/inspection.sh run",
        "inspection:latest": "bash ./.commanding/sh/inspection.sh latest",
        "inspection:chat": "bash ./.commanding/sh/inspection.sh chat",
        "inspection:baseline": "bash ./.commanding/sh/inspection.sh baseline",
        "inspection:compare": "bash ./.commanding/sh/inspection.sh compare",
        "cs:fix": "@php tools/php/php84.php vendor/bin/php-cs-fixer fix --config=.php-cs-fixer.php",
        "cs:check": "@php tools/php/php84.php vendor/bin/php-cs-fixer fix --config=.php-cs-fixer.php --dry-run --diff",
        "cs:check-quiet": "@php tools/php/php84.php vendor/bin/php-cs-fixer fix --config=.php-cs-fixer.php --dry-run",
        "stan:conservative": "tools/php/php82.php vendor/bin/phpstan analyse",
        "stan:runtime-target": "@php tools/php/php84.php vendor/bin/phpstan analyse",
        "md": "@php tools/php/php84.php vendor/bin/phpmd src,text phpmd.xml.dist",
        "md:tests": "@php tools/php/php84.php vendor/bin/phpmd tests,text phpmd.xml.dist",
        "test:unit": "@php tools/php/php84.php vendor/bin/phpunit -c phpunit.xml.dist --testsuite unit",
        "test:integration": "@php tools/php/php84.php vendor/bin/phpunit -c phpunit.xml.dist --testsuite integration",
        "test:e2e": "@php tools/php/php84.php vendor/bin/phpunit -c phpunit.xml.dist --testsuite e2e",
        "test:e2e:panther": [
            "@app:server:wait",
            "@php tools/php/php84.php vendor/bin/phpunit -c phpunit.xml.dist --testsuite e2e"
        ],
        "test:e2e:playwright": "npm run test:e2e",
        "test:e2e:full": [
            "@test:e2e:panther",
            "@test:e2e:playwright"
        ],
        "qa:style": [
            "@lint",
            "@cs:check"
        ],
        "qa:static": [
            "@stan"
        ],
        "qa:smell": [
            "@md",
            "@md:tests"
        ],
        "qa:test": [
            "@test"
        ],
        "qa:full": [
            "@qa:style",
            "@qa:static",
            "@qa:smell",
            "@qa:test"
        ],
        "smoke:runtime": "@php tools/php/php84.php tools/smoke/category-runtime-smoke.php",
        "smoke:fixtures": "@php tools/php/php84.php tools/smoke/category-fixture-sanity.php",
        "smoke:container": "@php tools/php/php84.php tools/smoke/category-container-boot-smoke.php",
        "smoke:doctrine": "@php tools/php/php84.php tools/smoke/category-doctrine-mapping-smoke.php",
        "smoke:fixture-load": "@php tools/php/php84.php tools/smoke/category-fixture-load-smoke.php",
        "smoke:graphql": "@php tools/php/php84.php tools/smoke/category-graphql-smoke.php",
        "report:owner-overlap": "@php tools/php/php84.php tools/inspection/AddressOwnerOverlapReport.php",
        "report:route-inventory": "@php tools/php/php84.php tools/inspection/AddressRouteInventoryReport.php",
        "report:class-alias": "@php tools/php/php84.php tools/inspection/AddressClassAliasReport.php",
        "report:runtime-proof": "@php tools/php/php84.php tools/inspection/AddressRuntimeProofReport.php",
        "test:security": "@php tools/php/php84.php vendor/bin/phpunit -c phpunit.xml.dist --testsuite security",
        "security:composer-audit": "composer audit --locked --no-interaction",
        "security:importmap-audit": "@php tools/qa/ImportmapAudit.php",
        "security:gitleaks": "@php tools/qa/LocalSecurityRunner.php gitleaks",
        "security:semgrep-ce": "@php tools/qa/LocalSecurityRunner.php semgrep-ce",
        "security:semgrep": "@security:semgrep-ce",
        "security:full": [
            "@security:composer-audit",
            "@security:importmap-audit",
            "@security:gitleaks",
            "@security:semgrep-ce",
            "@test:security"
        ],
        "pipeline:local:security": [
            "@security:full"
        ],
        "pipeline:local:full": [
            "@qa:full",
            "@security:full"
        ],
        "test:functional": "@php tools/php/php84.php vendor/bin/phpunit -c phpunit.xml.dist --testsuite functional",
        "fixtures:demo": "php bin/address-demo-reset 50",
        "app:server": "php -S 127.0.0.1:8000 -t public public/router.php",
        "app:server:wait": "@php tools/e2e/wait-for-url.php http://127.0.0.1:8000/address/manage",
        "app:server:dry-run": "@php tools/e2e/dry-run-server.php"
    },
    "config": {
        "sort-packages": true,
        "preferred-install": "dist"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
