{
  "name": "your-org/address-engine",
  "description": "AddressEngine \u2014 domain-driven Address library with Symfony & ApiPlatform integration",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": "^8.2",
    "doctrine/orm": "^2.15 || ^3.0",
    "symfony/framework-bundle": "^6.4 || ^7.0",
    "symfony/property-access": "^6.4 || ^7.0",
    "symfony/property-info": "^6.4 || ^7.0",
    "symfony/serializer": "^6.4 || ^7.0",
    "symfony/uid": "^7.3",
    "symfony/validator": "^6.4 || ^7.0",
    "ext-pdo": "*",
    "ext-curl": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5",
    "behat/behat": "^3.14",
    "friends-of-behat/symfony-extension": "^2.1",
    "phpstan/phpstan": "^1.11",
    "vimeo/psalm": "dev-master",
    "rector/rector": "^1.2"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "lint": "php -l $(git diff --cached --name-only --diff-filter=ACMRT | grep '\\.php$')",
    "phpstan": "vendor/bin/phpstan analyse src --level=max",
    "psalm": "vendor/bin/psalm",
    "test": "vendor/bin/phpunit --configuration phpunit.xml.dist",
    "stan": "vendor/bin/phpstan analyse",
    "rector:dry": "vendor/bin/rector process --dry-run",
    "quality": [
      "@stan",
      "@rector:dry"
    ]
  },
  "config": {
    "sort-packages": true,
    "preferred-install": "dist"
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}
