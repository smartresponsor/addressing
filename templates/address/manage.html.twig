<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Address manager</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
<main class="container py-5">
    <div class="row justify-content-center">
        <div class="col-xl-10">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4 p-lg-5">
                    <div class="d-flex justify-content-between align-items-start flex-column flex-lg-row gap-3">
                        <div>
                            <h1 class="h2 mb-2">Address manager</h1>
                            <p class="text-secondary mb-0">Create canonical address records through the Symfony demo flow built on DTOs, Forms, Twig and Bootstrap.</p>
                        </div>
                        <div class="badge text-bg-dark fs-6">Symfony demo</div>
                    </div>

                    {% if createdId %}
                        <div class="alert alert-success mt-4 mb-0">
                            Address created successfully: <strong>{{ createdId }}</strong>
                        </div>
                    {% endif %}

                    {{ form_start(manageForm, { attr: { class: 'row g-3 mt-1' } }) }}
                        <div class="col-md-6">{{ form_row(manageForm.line1) }}</div>
                        <div class="col-md-6">{{ form_row(manageForm.line2) }}</div>
                        <div class="col-md-4">{{ form_row(manageForm.city) }}</div>
                        <div class="col-md-3">{{ form_row(manageForm.region) }}</div>
                        <div class="col-md-3">{{ form_row(manageForm.postalCode) }}</div>
                        <div class="col-md-2">{{ form_row(manageForm.countryCode) }}</div>
                        <div class="col-md-6">{{ form_row(manageForm.ownerId) }}</div>
                        <div class="col-md-6">{{ form_row(manageForm.vendorId) }}</div>
                        <div class="col-12 d-flex align-items-center gap-3">
                            {{ form_widget(manageForm.save, { attr: { class: 'btn btn-primary px-4' } }) }}
                            <span class="text-secondary small">Provide owner or vendor scope to preview the latest records below.</span>
                        </div>
                    {{ form_end(manageForm) }}
                </div>
            </div>

            <div class="card shadow-sm border-0 mt-4">
                <div class="card-body p-4">
                    <h2 class="h5 mb-3">Latest scoped addresses</h2>
                    {% if previewRows is empty %}
                        <p class="text-secondary mb-0">No preview yet. Submit the form with an owner or vendor scope to see the latest records for that slice.</p>
                    {% else %}
                        <div class="table-responsive">
                            <table class="table table-sm align-middle mb-0">
                                <thead>
                                <tr>
                                    <th>ID</th>
                                    <th>Line 1</th>
                                    <th>City</th>
                                    <th>Country</th>
                                    <th>Validation</th>
                                    <th>Governance</th>
                                </tr>
                                </thead>
                                <tbody>
                                {% for row in previewRows %}
                                    <tr>
                                        <td><code>{{ row.id }}</code></td>
                                        <td>{{ row.line1 }}</td>
                                        <td>{{ row.city }}</td>
                                        <td>{{ row.countryCode }}</td>
                                        <td>{{ row.validationStatus }}</td>
                                        <td>{{ row.governanceStatus }}</td>
                                    </tr>
                                {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</main>
</body>
</html>
