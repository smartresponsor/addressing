<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <title>Address manager</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
</head>
<body class="bg-light">
<div class="container py-4">
    <h1 class="mb-4">Address manager</h1>

    {% if createdId is not null %}
        <div class="alert alert-success">Address created: <strong>{{ createdId }}</strong></div>
    {% endif %}

    <div class="card shadow-sm">
        <div class="card-body">
            {{ form_start(form) }}
            <div class="row g-3">
                <div class="col-md-6">{{ form_row(form.ownerId) }}</div>
                <div class="col-md-6">{{ form_row(form.vendorId) }}</div>
                <div class="col-md-8">{{ form_row(form.line1) }}</div>
                <div class="col-md-4">{{ form_row(form.line2) }}</div>
                <div class="col-md-4">{{ form_row(form.city) }}</div>
                <div class="col-md-4">{{ form_row(form.region) }}</div>
                <div class="col-md-4">{{ form_row(form.postalCode) }}</div>
                <div class="col-md-4">{{ form_row(form.countryCode) }}</div>
                <div class="col-12">{{ form_row(form.save) }}</div>
            </div>
            {{ form_end(form) }}
        </div>
    </div>
</div>
</body>
</html>
