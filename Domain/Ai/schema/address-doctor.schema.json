{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Address Doctor",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "component",
    "generatedAt",
    "ok",
    "issue",
    "tool",
    "env",
    "repo"
  ],
  "properties": {
    "component": {
      "type": "string"
    },
    "generatedAt": {
      "type": "string"
    },
    "ok": {
      "type": "boolean"
    },
    "issue": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "tool": {
      "type": "object"
    },
    "env": {
      "type": "object"
    },
    "repo": {
      "type": "object"
    },
    "note": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}