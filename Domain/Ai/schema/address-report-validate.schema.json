{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Address Report Validate",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "component",
    "generatedAt",
    "ok",
    "item"
  ],
  "properties": {
    "component": {
      "type": "string"
    },
    "generatedAt": {
      "type": "string"
    },
    "ok": {
      "type": "boolean"
    },
    "item": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "name",
          "path",
          "ok"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "ok": {
            "type": "boolean"
          },
          "issue": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "note": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}