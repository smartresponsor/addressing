#!/usr/bin/env php
<?php
declare(strict_types=1);
/*
 * Copyright (c) 2025 Oleksandr Tishchenko / Marketing America Corp
 * Author: Oleksandr Tishchenko <dev@smartresponsor.com>
 * Owner: Marketing America Corp
 */
use PDO;

$cmd = $argv[1] ?? null;
if (!$cmd) {
    fwrite(STDERR, "Usage: address-index-policy <enable-trgm|disable-trgm|enable-composite|disable-composite>\n");
    exit(2);
}
$pdo = new PDO(getenv('PG_DSN'), getenv('PG_USER'), getenv('PG_PASS'), [PDO::ATTR_ERRMODE=>PDO::ERRMODE_EXCEPTION]);

switch ($cmd) {
    case 'enable-trgm':
        $pdo->exec("CREATE EXTENSION IF NOT EXISTS pg_trgm");
        $pdo->exec("CREATE INDEX IF NOT EXISTS address_q_trgm_idx ON address_entity USING gin ((lower(line1 || ' ' || city || ' ' || coalesce(postal_code,''))) gin_trgm_ops)");
        echo "Trigram index enabled.\n"; break;
    case 'disable-trgm':
        $pdo->exec("DROP INDEX IF EXISTS address_q_trgm_idx");
        echo "Trigram index disabled.\n"; break;
    case 'enable-composite':
        $pdo->exec("CREATE INDEX IF NOT EXISTS address_country_city_id_idx ON address_entity(country_code, city, id)");
        $pdo->exec("CREATE INDEX IF NOT EXISTS address_owner_id_idx ON address_entity(owner_id, id)");
        $pdo->exec("CREATE INDEX IF NOT EXISTS address_vendor_id_idx ON address_entity(vendor_id, id)");
        echo "Composite index set enabled.\n"; break;
    case 'disable-composite':
        $pdo->exec("DROP INDEX IF EXISTS address_country_city_id_idx");
        $pdo->exec("DROP INDEX IF EXISTS address_owner_id_idx");
        $pdo->exec("DROP INDEX IF EXISTS address_vendor_id_idx");
        echo "Composite index set disabled.\n"; break;
    default:
        fwrite(STDERR, "Unknown command\n"); exit(2);
}
