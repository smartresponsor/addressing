#!/usr/bin/env php
<?php
# Copyright (c) 2025 Oleksandr Tishchenko / Marketing America Corp
declare(strict_types=1);

$ttlDays = (int)(getenv('ADDRESS_DELETE_TTL_DAYS') ?: 30);
$pg = new PDO(getenv('PG_DSN'), getenv('PG_USER'), getenv('PG_PASS'), [PDO::ATTR_ERRMODE => PDO::ERRMODE_EXCEPTION]);
$my = new PDO(getenv('MY_DSN'), getenv('MY_USER'), getenv('MY_PASS'), [PDO::ATTR_ERRMODE => PDO::ERRMODE_EXCEPTION]);

$pg->beginTransaction();
try {
    // collect ids to purge
    $sel = $pg->prepare("SELECT id FROM address_entity WHERE deleted_at IS NOT NULL AND deleted_at < now() - (:ttl || ' day')::interval");
    $sel->execute([':ttl' => (string)$ttlDays]);
    $ids = $sel->fetchAll(PDO::FETCH_COLUMN);

    if ($ids) {
        // hard delete from Postgres
        $in = implode(',', array_map(fn($i) => $pg->quote($i), $ids));
        $pg->exec("DELETE FROM address_entity WHERE id IN ($in)");
        // purge projection
        $inMy = implode(',', array_fill(0, count($ids), '?'));
        $stmt = $my->prepare("DELETE FROM address_projection WHERE id IN ($inMy)");
        $stmt->execute($ids);
    }
    $pg->commit();
    echo 'Purged ' . count($ids) . " rows (TTL {$ttlDays} days)\n";
} catch (Throwable $e) {
    $pg->rollBack();
    fwrite(STDERR, 'Error: ' . $e->getMessage() . "\n");
    exit(1);
}
