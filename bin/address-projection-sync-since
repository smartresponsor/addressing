 * Author: Oleksandr Tishchenko <dev@smartresponsor.com>
 * Owner: Marketing America Corp
 */

require __DIR__ . '/../vendor/autoload.php';

use App\Entity\Record\Address\AddressData;
use App\Service\Application\Address\AddressProjection;

/**
 * @param $v
 * @return array|null
 */
/**
 * @param $v
 * @return array|null
 */
function decodeJsonNullable($v): ?array
{
    if ($v === null) {
        return null;
    }
    if (!is_string($v) || $v === '') {
        return null;
    }
    $d = json_decode($v, true);
    return is_array($d) ? $d : null;
}

/**
 * @param array $r
 * @param string $k
 * @return bool|null
 */
function toBoolNullable(array $r, string $k): ?bool
{
    if (!array_key_exists($k, $r) || $r[$k] === null) {
        return null;
    }
    $v = $r[$k];
    if (is_bool($v)) {
        return $v;
    }
    if (is_int($v)) {
        return $v === 1;
    }
    if (is_string($v)) {
        $s = strtolower(trim($v));
        return in_array($s, ['1', 't', 'true', 'yes'], true);
    }
    return null;
}

if ($argc < 2) {
    fwrite(STDERR, "Usage: address-projection-sync-since <ISO8601-timestamp>\n");
    exit(2);
}

$since = (string)$argv[1];

$pg = new PDO((string)getenv('PG_DSN'), (string)getenv('PG_USER'), (string)getenv('PG_PASS'), [PDO::ATTR_ERRMODE => PDO::ERRMODE_EXCEPTION]);
$my = new PDO((string)getenv('MY_DSN'), (string)getenv('MY_USER'), (string)getenv('MY_PASS'), [PDO::ATTR_ERRMODE => PDO::ERRMODE_EXCEPTION]);
$proj = new AddressProjection($my);

$sql = 'SELECT * FROM address_entity WHERE (updated_at IS NOT NULL AND updated_at > :since) OR (created_at > :since) ORDER BY updated_at NULLS LAST, created_at';
$stmt = $pg->prepare($sql);
$stmt->execute([':since' => $since]);

$cnt = 0;
while ($r = $stmt->fetch(PDO::FETCH_ASSOC)) {
    $validationRaw = decodeJsonNullable($r['validation_raw'] ?? null);
    $validationVerdict = decodeJsonNullable($r['validation_verdict'] ?? null);
    $validationDeliverable = toBoolNullable($r, 'validation_deliverable');

    $a = new AddressData(
        (string)$r['id'],
        $r['owner_id'] !== null ? (string)$r['owner_id'] : null,
        $r['vendor_id'] !== null ? (string)$r['vendor_id'] : null,
        (string)$r['line1'],
        $r['line2'] !== null ? (string)$r['line2'] : null,
        (string)$r['city'],
        $r['region'] !== null ? (string)$r['region'] : null,
        $r['postal_code'] !== null ? (string)$r['postal_code'] : null,
        (string)$r['country_code'],
        $r['line1_norm'] !== null ? (string)$r['line1_norm'] : null,
        $r['city_norm'] !== null ? (string)$r['city_norm'] : null,
        $r['region_norm'] !== null ? (string)$r['region_norm'] : null,
        $r['postal_code_norm'] !== null ? (string)$r['postal_code_norm'] : null,
        $r['latitude'] !== null ? (float)$r['latitude'] : null,
        $r['longitude'] !== null ? (float)$r['longitude'] : null,
        $r['geohash'] !== null ? (string)$r['geohash'] : null,
        (string)$r['validation_status'],
        $r['validation_provider'] !== null ? (string)$r['validation_provider'] : null,
        $r['validated_at'] !== null ? (string)$r['validated_at'] : null,
        $r['dedupe_key'] !== null ? (string)$r['dedupe_key'] : null,
        (string)$r['created_at'],
        $r['updated_at'] !== null ? (string)$r['updated_at'] : null,
        $r['deleted_at'] !== null ? (string)$r['deleted_at'] : null,
        $r['validation_fingerprint'] !== null ? (string)$r['validation_fingerprint'] : null,
        $validationRaw,
        $validationVerdict,
        $validationDeliverable,
        $r['validation_granularity'] !== null ? (string)$r['validation_granularity'] : null,
        $r['validation_quality'] !== null ? (int)$r['validation_quality'] : null,
    );

    $proj->upsert($a);
    $cnt++;
}

echo "Projection synced rows: {$cnt}\n";
