#!/usr/bin/env php
<?php
declare(strict_types=1);
/*
 * Copyright (c) 2025 Oleksandr Tishchenko / Marketing America Corp
 * Author: Oleksandr Tishchenko <dev@smartresponsor.com>
 * Owner: Marketing America Corp
 */
use PDO;

$pg = new PDO(getenv('PG_DSN'), getenv('PG_USER'), getenv('PG_PASS'), [PDO::ATTR_ERRMODE=>PDO::ERRMODE_EXCEPTION]);

$pending = (int)$pg->query("SELECT count(*) FROM address_outbox WHERE published_at IS NULL")->fetchColumn();
$published = (int)$pg->query("SELECT count(*) FROM address_outbox WHERE published_at IS NOT NULL")->fetchColumn();
$failed = (int)$pg->query("SELECT count(*) FROM address_outbox WHERE published_at IS NULL AND published_attempt > 0 AND last_error IS NOT NULL")->fetchColumn();

$total = (int)$pg->query("SELECT count(*) FROM address_entity")->fetchColumn();
$validated = (int)$pg->query("SELECT count(*) FROM address_entity WHERE validation_status = 'validated'")->fetchColumn();
$normalized = (int)$pg->query("SELECT count(*) FROM address_entity WHERE validation_status = 'normalized'")->fetchColumn();

header('Content-Type: text/plain');

echo "# HELP address_outbox_pending_total Pending events in outbox\n";
echo "# TYPE address_outbox_pending_total gauge\n";
echo "address_outbox_pending_total {$pending}\n";

echo "# HELP address_outbox_published_total Published events in outbox\n";
echo "# TYPE address_outbox_published_total counter\n";
echo "address_outbox_published_total {$published}\n";

echo "# HELP address_outbox_failed_total Failed events awaiting retry\n";
echo "# TYPE address_outbox_failed_total gauge\n";
echo "address_outbox_failed_total {$failed}\n";

echo "# HELP address_entity_total Total address entity rows\n";
echo "# TYPE address_entity_total gauge\n";
echo "address_entity_total {$total}\n";

echo "# HELP address_entity_validated_total Address rows with validated status\n";
echo "# TYPE address_entity_validated_total gauge\n";
echo "address_entity_validated_total {$validated}\n";

echo "# HELP address_entity_normalized_total Address rows with normalized status\n";
echo "# TYPE address_entity_normalized_total gauge\n";
echo "address_entity_normalized_total {$normalized}\n";
