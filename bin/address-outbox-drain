declare(strict_types=1);


require __DIR__ . '/../vendor/autoload.php';

use App\Service\Application\AddressOutboxDrainerService;
use JetBrains\PhpStorm\NoReturn;

/**
 * @return void
 */
#[NoReturn] function usage(): void
{
    fwrite(STDERR, "Usage: address-outbox-drain <url> [--limit=200] [--retry=3] [--timeout=5] [--backoff=100]\n");
    exit(2);
}

/**
 * @param array $argv
 * @param string $prefix
 * @param int $default
 * @return int
 */
function readIntOpt(array $argv, string $prefix, int $default): int
{
    foreach ($argv as $a) {
        if (str_starts_with($a, $prefix . '=')) {
            $val = substr($a, strlen($prefix) + 1);
            if (is_numeric($val)) {
                return (int)$val;
            }
        }
    }
    return $default;
}

$url = $argv[1] ?? null;
if (!is_string($url) || $url === '' || str_starts_with($url, '--')) {
    usage();
}

$limit = readIntOpt($argv, '--limit', 200);
$retry = readIntOpt($argv, '--retry', 3);
$timeout = readIntOpt($argv, '--timeout', 5);
$backoff = readIntOpt($argv, '--backoff', 100);

$pdo = new PDO((string)getenv('PG_DSN'), (string)getenv('PG_USER'), (string)getenv('PG_PASS'), [
    PDO::ATTR_ERRMODE => PDO::ERRMODE_EXCEPTION,
]);

$drainer = new AddressOutboxDrainerService($pdo);
$count = $drainer->drain($url, $limit, $retry, $timeout, $backoff);

fwrite(STDOUT, "Drained: {$count}\n");
