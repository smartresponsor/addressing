 * Owner: Marketing America Corp
 */

$ttlDays = (int) (getenv('ADDRESS_AUDIT_TTL_DAYS') ?: 90);
$pdo = new PDO(getenv('PG_DSN'), getenv('PG_USER'), getenv('PG_PASS'), [PDO::ATTR_ERRMODE=>PDO::ERRMODE_EXCEPTION]);

$stmt = $pdo->prepare("DELETE FROM address_audit WHERE changed_at < now() - (:ttl || ' day')::interval");
$stmt->execute([':ttl' => (string)$ttlDays]);
echo 'Audit purged rows: ' .$stmt->rowCount()."\n";
