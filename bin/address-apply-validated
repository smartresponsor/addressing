#!/usr/bin/env php
<?php
# Copyright (c) 2025 Oleksandr Tishchenko / Marketing America Corp
declare(strict_types=1);

require __DIR__ . '/../vendor/autoload.php';

use App\Contract\Message\AddressValidated;
use App\Service\Application\AddressValidatedApplierService;
use JetBrains\PhpStorm\NoReturn;

#[NoReturn] function usage(): void
{
    fwrite(STDERR, "Usage: address-apply-validated <json-file>|- (NDJSON or single JSON)\n");
    exit(2);
}

$arg = $argv[1] ?? null;
if (!$arg) {
    usage();
}

$pdo = new PDO((string)getenv('PG_DSN'), (string)getenv('PG_USER'), (string)getenv('PG_PASS'), [
    PDO::ATTR_ERRMODE => PDO::ERRMODE_EXCEPTION,
]);
$applier = new AddressValidatedApplierService($pdo);

$handle = ($arg === '-') ? STDIN : fopen($arg, 'r');
if (!$handle) {
    fwrite(STDERR, "Cannot open input\n");
    exit(2);
}

$buf = stream_get_contents($handle);
$trim = trim((string)$buf);
if ($trim === '') {
    fwrite(STDERR, "Empty input\n");
    exit(2);
}

$dataSet = [];
if (str_contains($trim, "\n")) {
    foreach (explode("\n", $trim) as $line) {
        $line = trim($line);
        if ($line === '') {
            continue;
        }
        $obj = json_decode($line, true);
        if (!is_array($obj)) {
            continue;
        }
        $dataSet[] = $obj;
    }
} else {
    $obj = json_decode($trim, true);
    if (!is_array($obj)) {
        fwrite(STDERR, "Invalid JSON\n");
        exit(2);
    }
    if (isset($obj[0]) && is_array($obj[0])) {
        foreach ($obj as $item) {
            if (is_array($item)) {
                $dataSet[] = $item;
            }
        }
    } else {
        $dataSet[] = $obj;
    }
}

$ok = 0;
$fail = 0;
foreach ($dataSet as $event) {
    try {
        $id = $event['id'] ?? null;
        if (!is_string($id) || $id === '') {
            $fail++;
            continue;
        }

        $ownerId = isset($event['ownerId']) && is_string($event['ownerId']) && $event['ownerId'] !== '' ? $event['ownerId'] : null;
        $vendorId = isset($event['vendorId']) && is_string($event['vendorId']) && $event['vendorId'] !== '' ? $event['vendorId'] : null;

        $payload = $event;
        unset($payload['id'], $payload['ownerId'], $payload['vendorId']);

        $validated = AddressValidated::fromArray($payload);
        $applier->apply($id, $validated, $ownerId, $vendorId);
        $ok++;
    } catch (Throwable $exception) {
        $fail++;
        fwrite(STDERR, 'Error: ' . $exception->getMessage() . "\n");
    }
}

fwrite(STDOUT, "Applied: {$ok}, Failed: {$fail}\n");
